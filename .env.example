# API keys for baseline comparison runs
# Copy this file to .env and fill in your keys
# NEVER commit .env to git

# Primary — one key for all models (recommended)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# Fallback — individual provider keys (optional, used if OPENROUTER_API_KEY not set)
ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_API_KEY=your-google-ai-studio-key-here
GROQ_API_KEY=gsk_your-groq-key-here
TOGETHER_API_KEY=your-together-key-here
